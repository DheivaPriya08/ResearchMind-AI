# Copy this file to .env and fill in your key, or just paste the key into
# the sidebar text box when the app is running -- either works.
# You only need ONE of these, matching whichever provider you pick in the
# sidebar's "LLM Provider" dropdown.

# OpenAI (platform.openai.com) -- requires billing set up
OPENAI_API_KEY=sk-your-key-here

# Google Gemini (aistudio.google.com) -- has a free tier
GOOGLE_API_KEY=your-google-ai-studio-key-here
